# Database (Supabase PostgreSQL - direct connection)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT Secret (random 32+ character string)
JWT_SECRET=generate-a-random-32-character-string-here

# Storage Provider: 'aws' or 'supabase'
STORAGE_PROVIDER=aws

# --- AWS S3 (when STORAGE_PROVIDER=aws) ---
S3_BUCKET=alok-central-school
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=YOUR_AWS_KEY
S3_SECRET_ACCESS_KEY=YOUR_AWS_SECRET

# --- Supabase Storage (when STORAGE_PROVIDER=supabase) ---
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_S3_ACCESS_KEY=YOUR_SUPABASE_S3_KEY
# SUPABASE_S3_SECRET_KEY=YOUR_SUPABASE_S3_SECRET
# SUPABASE_S3_BUCKET=alok-central-school

# Admin Credentials (used by seed script: npm run seed)
ADMIN_EMAIL=admin@alokcentralschool.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Admin

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:4200
