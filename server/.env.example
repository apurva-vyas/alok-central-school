# Database (Supabase PostgreSQL - direct connection)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT Secret (random 32+ character string)
JWT_SECRET=generate-a-random-32-character-string-here

# Storage Provider: 'aws' or 'supabase'
STORAGE_PROVIDER=aws

# --- AWS S3 (when STORAGE_PROVIDER=aws) ---
AWS_S3_BUCKET=alok-central-school
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET

# --- Supabase Storage (when STORAGE_PROVIDER=supabase) ---
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Get S3 keys from: Supabase Dashboard > Settings > Storage > S3 Connection
SUPABASE_S3_ACCESS_KEY=YOUR_SUPABASE_S3_KEY
SUPABASE_S3_SECRET_KEY=YOUR_SUPABASE_S3_SECRET
SUPABASE_S3_BUCKET=images

# CORS
CORS_ORIGIN=http://localhost:4200
